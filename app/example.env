# OpenAI API Configuration
OPENAI_API_KEY=

# OpenRouter API Configuration (Alternative to save cost)
# Get your API key at https://openrouter.ai/
OPENROUTER_API_KEY=
# Optional: Set a specific model (e.g., google/gemini-2.5-flash, meta-llama/llama-3-8b-instruct:free, etc.)
OPENROUTER_MODEL=

# Email Configuration (Gmail SMTP)
MY_EMAIL=
APP_PASSWORD=

# Webshare Proxy
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=

# Environment Configuration
# Set to LOCAL for local development, PRODUCTION for production (Render)
# If not set, defaults to LOCAL
ENVIRONMENT=LOCAL

# Lookback hours for daily scraping (defaults to 24)
SCRAPE_HOURS=24

# Database Configuration
# For Render: DATABASE_URL is automatically provided, no need to set individual vars
# For Local Development: Use individual POSTGRES_* variables below
DATABASE_URL=

# Local Development Database (only needed if DATABASE_URL is not set)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_news_aggregator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

